---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();
---

<Layout title={post.data.title} description={post.data.description}>
  <article class="container-page py-12">
    <header class="mb-8 border-b border-gray-200 dark:border-gray-800 pb-6">
      <h1 class="text-4xl font-light mb-3">{post.data.title}</h1>
      <p class="text-sm text-gray-600 dark:text-gray-400">
        {post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
      </p>
      {post.data.tags && (
        <div class="flex gap-1.5 mt-3">
          {post.data.tags.map((tag) => (
            <span class="px-2 py-0.5 text-xs rounded bg-gray-100 dark:bg-gray-800 text-gray-700 dark:text-gray-300">{tag}</span>
          ))}
        </div>
      )}
    </header>

    <div class="prose dark:prose-invert max-w-none prose-headings:font-light blog-prose">
      <Content />
    </div>

    <div class="mt-12 pt-6" style="border-top: 1px solid var(--color-border);">
      <a href="/blog" class="text-sm text-accent">← back to blog</a>
    </div>
  </article>
</Layout>
