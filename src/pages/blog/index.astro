---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<Layout title="blog" description="Research notes and articles by Mohsin Imam">
  <div class="container-page py-12">
    <h1 class="heading-page">Blog</h1>
    <p class="subtitle-page">Research notes, paper reviews, and technical articles</p>

    {posts.length === 0 ? (
      <p class="text-gray-600 dark:text-gray-400 mt-8">No posts yet. Check back soon!</p>
    ) : (
      <div class="space-y-6">
        {posts.map((post) => (
          <article class="border-b border-gray-200 dark:border-gray-800 pb-6">
            <a href={`/blog/${post.slug}`} class="block hover:no-underline group">
              <h2 class="text-xl font-medium group-hover:text-accent transition-colors">{post.data.title}</h2>
              <p class="text-sm text-gray-600 dark:text-gray-400 mt-1">
                {post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
              </p>
              <p class="mt-2 text-gray-700 dark:text-gray-300">{post.data.description}</p>
              {post.data.tags && (
                <div class="flex gap-1.5 mt-2">
                  {post.data.tags.map((tag) => (
                    <span class="px-2 py-0.5 text-xs rounded bg-gray-100 dark:bg-gray-800 text-gray-700 dark:text-gray-300">{tag}</span>
                  ))}
                </div>
              )}
            </a>
          </article>
        ))}
      </div>
    )}
  </div>
</Layout>
